# mestbak-checker — Omgevingsvariabelen
# Kopieer dit bestand naar .env en vul de waarden in
# Commit NOOIT het .env bestand naar Git!

# ─── TextMeBot ───────────────────────────────────────────────────────────────
TEXTMEBOT_API_KEY=jouw_textmebot_api_key_hier

# ─── Eigen nummer voor samenvattingsberichten ────────────────────────────────
# E.164 formaat: +31612345678
SUMMARY_PHONE=+31612345678

# ─── Database ────────────────────────────────────────────────────────────────
DB_SERVER=<db-server>
DB_NAME=<db-naam>
DB_CLIENT_NO=3582
DB_DRIVER=ODBC Driver 17 for SQL Server

# ─── Testmodus ───────────────────────────────────────────────────────────────
# Zet op true om testmodus te activeren (geen echte DB query)
TEST_MODE=false
TEST_PHONE_NL=+31612345678
TEST_PHONE_BE=+32498123456
TEST_PHONE_DE=+4917612345678
